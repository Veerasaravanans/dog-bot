# ESP32-CAM Configuration
ESP32_STREAM_URL=http://192.168.1.100:81/stream
ESP32_CONTROL_URL=http://192.168.1.100
ESP32_TIMEOUT=5.0

# VIO Cloud LLM Configuration
VIO_BASE_URL=https://vio.automotive-wan.com:446
VIO_USERNAME=your_vio_username
VIO_API_TOKEN=your_vio_api_token
VIO_TOKEN_EXPIRY=2026-10-10
VIO_PRIMARY_MODEL=claude-4-5-sonnet-v1:0
VIO_SSL_VERIFY=true

# CV Pipeline Configuration
CV_CONTOUR_MIN_AREA=1500
CV_CANNY_LOW=80
CV_CANNY_HIGH=200
CV_BLUR_KERNEL=5
CV_EDGE_GRADIENT_THRESHOLD=80

# ML Detection Configuration
ML_MODEL_PATH=models/footprint_yolov8n.pt
ML_CONFIDENCE_THRESHOLD=0.35
ML_DETECT_EVERY_N_FRAMES=2
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_MODEL=foot-print-detection/2

# AI Decision Configuration
AI_DECISION_INTERVAL=0.066
AI_MANUAL_PAUSE_SECONDS=5.0
AI_COMMAND_REISSUE_INTERVAL=0.5
AI_ANALYZE_DURATION=3.0
AI_ACT_DURATION=0.5

# MQTT Remote Connectivity (leave empty to disable)
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=true

# App Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
